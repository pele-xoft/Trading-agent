# ChartMind API Server — environment variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/chartmind
# Hosted:  postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/chartmind

# OpenAI API key — get one at https://platform.openai.com/api-keys
# Set to "mock" to run in demo mode (no API key needed, no cost)
OPENAI_API_KEY=sk-...

# Port the server listens on (default: 3000)
PORT=3000

# Set to "true" to force demo/mock mode even if OPENAI_API_KEY is set
MOCK_MODE=false
